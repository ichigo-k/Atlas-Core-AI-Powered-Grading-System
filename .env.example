# =============================================================================
# ai-powered-grading-system — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------

# Shared PostgreSQL database (Neon).
# Use sslmode=require for local dev (verify-full requires a local root cert).
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ---------------------------------------------------------------------------
# NextAuth (REQUIRED)
# ---------------------------------------------------------------------------

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Base URL of this app — required in production, optional in local dev
# NEXTAUTH_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# Grader service integration (REQUIRED when grading is enabled)
# ---------------------------------------------------------------------------

# Base URL of the verion-ai-grader Django service
# GRADER_URL=http://localhost:8000

# API key generated by: uv run python manage.py generate_api_key --label "main-system"
# GRADER_API_KEY=your-grader-api-key-here

# ---------------------------------------------------------------------------
# Oracle AI Proctoring service (OPTIONAL — omit all three to disable proctoring)
# ---------------------------------------------------------------------------

# Server-side base URL of the Oracle FastAPI service (used by API routes and
# server actions). When unset, the Portal falls back to the non-proctored exam
# flow and treats all assessments as proctoringEnabled = false.
# ORACLE_BASE_URL=http://localhost:8001

# Client-side base URL of Oracle — MUST match ORACLE_BASE_URL exactly.
# Requires the NEXT_PUBLIC_ prefix so Next.js exposes it to browser code
# (lighting check, WebRTC signaling). Both vars are needed; they cannot be merged.
# NEXT_PUBLIC_ORACLE_BASE_URL=http://localhost:8001

# Shared HMAC-SHA256 secret used to verify incoming Webhooks from Oracle.
# Must match ORACLE_WEBHOOK_SECRET in Oracle's .env.
# ORACLE_WEBHOOK_SECRET=your-secret-here

# LiveKit server URL — server-side only (NOT NEXT_PUBLIC_).
# This value is passed to the student browser only as part of the session-creation
# response from Oracle (the livekitUrl field). The Portal itself never connects to
# LiveKit directly; the student's browser does via the ProctorLiveKit SDK client.
# Must match LIVEKIT_URL in Oracle's .env (default: ws://localhost:7880).
# LIVEKIT_URL=ws://localhost:7880
