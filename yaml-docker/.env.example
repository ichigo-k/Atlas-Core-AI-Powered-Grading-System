# ═══════════════════════════════════════════════════════════════════════════════
# Hostinger VPS Deployment — Shared Environment Variables
# Copy to .env and fill in your values before running docker compose.
# This single .env powers BOTH compose files (portal + grader).
# ═══════════════════════════════════════════════════════════════════════════════


# ┌─────────────────────────────────────────────────────────────────────────────
# │ SHARED DATABASE (Neon — external, not managed by Docker)
# └─────────────────────────────────────────────────────────────────────────────

# The single source of truth for both services.
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech:5432/dbname?sslmode=require


# ┌─────────────────────────────────────────────────────────────────────────────
# │ EXAM PORTAL (Next.js)
# └─────────────────────────────────────────────────────────────────────────────

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_generate_a_real_secret

# Public URL of the portal (your domain or VPS IP)
NEXTAUTH_URL=https://exam.yourdomain.com

# Grader connection — uses Docker network name since both run on same VPS
GRADER_URL=http://verion-grader:8000

# Paste the key from:
#   docker compose -f docker-compose.grader.yml exec grader python manage.py generate_api_key --label "portal"
GRADER_API_KEY=CHANGE_ME_paste_generated_key

# Oracle AI Proctor (leave blank to disable proctoring entirely)
ORACLE_BASE_URL=
NEXT_PUBLIC_ORACLE_BASE_URL=
ORACLE_WEBHOOK_SECRET=
LIVEKIT_URL=

# Port exposed on VPS
PORTAL_PORT=3000


# ┌─────────────────────────────────────────────────────────────────────────────
# │ AI GRADER (Django)
# └─────────────────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_real_secret

# Allowed hosts (comma-separated) — your domain + localhost for healthcheck
ALLOWED_HOSTS=grader.yourdomain.com,localhost,verion-grader

# Leave False for production
DEBUG=False

# Port exposed on VPS
GRADER_PORT=8000

# Gunicorn tuning (2 × CPU cores + 1 is the rule of thumb)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=300


# ┌─────────────────────────────────────────────────────────────────────────────
# │ OLLAMA (Local LLM)
# └─────────────────────────────────────────────────────────────────────────────

# Model to pull after first start:
#   docker compose -f docker-compose.grader.yml exec ollama ollama pull llama3
OLLAMA_MODEL_ID=llama3

# Inference timeout — CPU inference is slow, be generous
OLLAMA_TIMEOUT=300

# Context window (tokens) — must fit the full rubric prompt
OLLAMA_NUM_CTX=4096

# Port exposed on VPS (usually only needed for debugging)
OLLAMA_PORT=11434


# ┌─────────────────────────────────────────────────────────────────────────────
# │ MINIO (S3-compatible storage for uploaded answer files)
# └─────────────────────────────────────────────────────────────────────────────

# Credentials — CHANGE THESE from the defaults!
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password

# Bucket settings
S3_BUCKET_NAME=grader-uploads
S3_UPLOAD_PREFIX=grader-uploads

# Ports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001


# ┌─────────────────────────────────────────────────────────────────────────────
# │ GRADER SYSTEM DATABASE (local PostgreSQL — NOT Neon)
# └─────────────────────────────────────────────────────────────────────────────
# This holds Django internals (auth_keys, migrations). It is NOT the shared DB.

POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
